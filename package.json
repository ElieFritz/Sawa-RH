{
  "name": "sawa-rh",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:api:render": "pnpm --filter @sawa-rh/shared build && pnpm --filter @sawa-rh/api build",
    "migrate:api:render": "pnpm --filter @sawa-rh/api prisma:migrate",
    "start:api:render": "pnpm --filter @sawa-rh/api start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "prisma:generate": "turbo run prisma:generate --filter=@sawa-rh/api",
    "prisma:migrate": "turbo run prisma:migrate --filter=@sawa-rh/api",
    "seed": "turbo run seed --filter=@sawa-rh/api"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3"
  }
}
